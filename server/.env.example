# Get your API key at https://ai.google.dev
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Specify a preferred Gemini model
# GEMINI_MODEL=gemini-2.0-flash

# Optional: Automatic fallback provider when Gemini is unavailable or quota-limited
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_MODEL=openrouter/auto
# OPENROUTER_FALLBACK_MODELS=anthropic/claude-3.5-sonnet,openai/gpt-4.1-mini

# Vercel KV — required for Share Links (Feature 2)
# Automatically injected by Vercel when you connect a KV store.
# For local dev, get these from your Vercel project settings > Storage.
# KV_REST_API_URL=https://your-kv.upstash.io
# KV_REST_API_TOKEN=your_token_here
